{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ArcForge",
  "version": "../package.json",
  "identifier": "com.nieli.arcforge",
  "build": {
    "beforeDevCommand": "pnpm dev:desktop",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:desktop",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "",
        "width": 1400,
        "height": 800,
        "minWidth": 1200,
        "minHeight": 720,
        "backgroundThrottling": "disabled"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "icon": [
      "icons/32x32-windows.png",
      "icons/128x128-windows.png",
      "icons/128x128@2x-windows.png",
      "icons/icon-windows.png",
      "icons/icon-windows.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon-windows.ico"
      }
    }
  }
}
